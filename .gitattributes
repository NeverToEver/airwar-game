* text=auto

# Python
*.py text eol=lf

# Rust
*.rs text eol=lf

# Config / Data
*.toml text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Documentation
*.md text eol=lf

# Shell scripts (if any added in the future)
*.sh text eol=lf

# Binary assets — Git should not try to merge/diff these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.ogg binary
*.ttf binary
*.otf binary
