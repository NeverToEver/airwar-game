# =============================================================================
# Air War - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
*.egg-info/
*.egg
.eggs/
eggs/
dist/
build/
develop-eggs/
downloads/
MANIFEST

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
.venv/
.venv-build/
env/
ENV/
Pipfile
Pipfile.lock
conda-meta/
*.conda

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.vscode/settings.json
*.code-workspace
.idea/
*.iml
.trae/*
.trae/settings.json

# Vim / Emacs / Nano
*.swp
*.swo
*.save
*~
\#*\#
.\#*
.Session

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
.tox/
.hypothesis/
*.cover
*.prof

# -----------------------------------------------------------------------------
# Type Checking / Linting
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSSharedFileList

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.env
secrets.*
credentials.*
*.pem
*.key
*.crt
*.cert

# -----------------------------------------------------------------------------
# Rust (airwar_core)
# -----------------------------------------------------------------------------
airwar_core/target/
/target/
Cargo.lock

# PyInstaller build artifacts
*.spec
*.spec.bak

# -----------------------------------------------------------------------------
# Game Runtime Data
# -----------------------------------------------------------------------------
data/
airwar/data/

# Legacy nested directory (from incorrect runs)
airwar/airwar/

# Game saves
*.sav
*.save

# Local config overrides
config/local.py
config/local_settings.py
config/override.py

# -----------------------------------------------------------------------------
# Logs / Temp / Cache
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.backup
*.cache
crash-reports/
tmp/
temp/

# Sprite / Render cache
sprite_cache/
texture_cache/
render_cache/

# Performance
*.profile
PERFORMANCE_REPORT.md

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/
plans/
